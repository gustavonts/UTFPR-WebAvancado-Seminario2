{% extends 'base.html.twig' %}

{% block title %}
    Pedidos
{% endblock %}


{% block body %}

<div class="container mt-4">

    <h1>
        Gerenciar Pedidos
    </h1>

    <a 
        href="{{ path('app_pedido_new') }}"
        class="btn btn-success mb-3">

        Novo pedido

    </a>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">Todos os status</option>
                <option value="AGUARDANDO_PAGAMENTO" {% if filtroStatus == 'AGUARDANDO_PAGAMENTO' %}selected{% endif %}>Aguardando pagamento</option>
                <option value="PAGO" {% if filtroStatus == 'PAGO' %}selected{% endif %}>Pago</option>
                <option value="EM_TRANSPORTE" {% if filtroStatus == 'EM_TRANSPORTE' %}selected{% endif %}>Em transporte</option>
                <option value="ENTREGUE" {% if filtroStatus == 'ENTREGUE' %}selected{% endif %}>Entregue</option>
                <option value="CANCELADO" {% if filtroStatus == 'CANCELADO' %}selected{% endif %}>Cancelado</option>
            </select>
        </div>

        <div class="col-md-4">
            <input type="text" name="cliente" class="form-control" placeholder="Filtrar por cliente" value="{{ filtroCliente }}">
        </div>

        <div class="col-md-3">
            <input type="date" name="data" class="form-control" value="{{ filtroData }}">
        </div>

        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            <a href="{{ path('app_pedidos') }}" class="btn btn-outline-secondary">Limpar</a>
        </div>
    </form>

    <table class="table table-hover shadow">

        <thead>
            <tr>
                <th>Número</th>
                <th>Cliente</th>
                <th>Email</th>
                <th>Status</th>
                <th>Total</th>
                <th>Ação</th>
            </tr>
        </thead>

        <tbody>

        {% for pedido in pedidos %}

            <tr>
                <td>
                    {{ pedido.number }}
                </td>

                <td>
                    {{ pedido.customerName }}
                </td>

                <td>
                    {{ pedido.customerEmail }}
                </td>

                <td>
                    <span class="badge bg-primary">
                        {{ pedido.status }}
                    </span>
                </td>

                <td>
                    {% set valorTotal = 0 %}
                    {% for item in pedido.orderItems %}
                        {% set valorTotal = valorTotal + (item.precoUnitario * item.quantidade) %}
                    {% endfor %}
                    R$ {{ valorTotal|number_format(2, ',', '.') }}
                </td>

                <td>
                    <a 
                    href="{{ path('app_pedido_show', {id: pedido.id}) }}"
                    class="btn btn-sm btn-primary">
                        Ver
                    </a>
                    <a 
                    href="{{ path('app_pedido_delete', {id: pedido.id}) }}"
                    class="btn btn-sm btn-danger">
                        Excluir
                    </a>
                </td>

            </tr>

        {% endfor %}

        </tbody>

    </table>

</div>

{% endblock %}