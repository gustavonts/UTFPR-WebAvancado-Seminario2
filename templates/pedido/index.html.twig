{% extends 'base.html.twig' %}

{% block title %}
    Pedidos
{% endblock %}


{% block body %}

<div class="container mt-4">

    <h1>
        Gerenciar Pedidos
    </h1>

    <a 
        href="{{ path('app_pedido_new') }}"
        class="btn btn-success mb-3">

        Novo pedido

    </a>

    <table class="table table-hover shadow">

        <thead>
            <tr>
                <th>Número</th>
                <th>Cliente</th>
                <th>Email</th>
                <th>Status</th>
                <th>Total</th>
                <th>Ação</th>
            </tr>
        </thead>

        <tbody>

        {% for pedido in pedidos %}

            <tr>
                <td>
                    {{ pedido.number }}
                </td>

                <td>
                    {{ pedido.customerName }}
                </td>

                <td>
                    {{ pedido.customerEmail }}
                </td>

                <td>
                    <span class="badge bg-primary">
                        {{ pedido.status }}
                    </span>
                </td>

                <td>
                    {% set valorTotal = 0 %}
                    {% for item in pedido.orderItems %}
                        {% set valorTotal = valorTotal + (item.precoUnitario * item.quantidade) %}
                    {% endfor %}
                    R$ {{ valorTotal|number_format(2, ',', '.') }}
                </td>

                <td>
                    <a 
                    href="{{ path('app_pedido_show', {id: pedido.id}) }}"
                    class="btn btn-sm btn-primary">
                        Ver
                    </a>
                    <a 
                    href="{{ path('app_pedido_delete', {id: pedido.id}) }}"
                    class="btn btn-sm btn-danger">
                        Excluir
                    </a>
                </td>

            </tr>

        {% endfor %}

        </tbody>

    </table>

</div>

{% endblock %}