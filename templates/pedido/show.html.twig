{% extends 'base.html.twig' %}


{% block title %}
    Pedido
{% endblock %}


{% block body %}

<div class="container mt-4">


    <h1>
        Pedido #{{ pedido.number }}
    </h1>


    <div class="card shadow">


        <div class="card-body">


            <h4>
                Cliente
            </h4>


            <p>
                {{ pedido.customerName }}
            </p>


            <p>
                {{ pedido.customerEmail }}
            </p>


            <hr>


            <h4>
                Informações
            </h4>


            <h3>
                Produtos
            </h3>


            <ul class="list-group">


            {% for item in pedido.orderItems %}


                <li class="list-group-item">


                    {{ item.produto.nome }}

                    {% if item.produto.categoria %}
                        ({{ item.produto.categoria.nome }})
                    {% endif %}

                    -

                    Quantidade:
                    {{ item.quantidade }}

                    -

                    R$ {{ item.precoUnitario }}


                </li>


            {% else %}


                <li class="list-group-item">

                    Nenhum produto

                </li>


            {% endfor %}


            </ul>



            <form
                method="post"
                action="{{ path('app_pedido_produto_add', {id: pedido.id}) }}"
                class="mt-3">


                <h5>
                    Adicionar produto
                </h5>


                <select
                    name="produto"
                    class="form-select">


                    {% for produto in produtos %}


                        <option value="{{ produto.id }}">

                            {{ produto.nome }}

                            -

                            R$ {{ produto.preco }}

                        </option>


                    {% endfor %}


                </select>



                <input
                    type="number"
                    name="quantidade"
                    class="form-control mt-2"
                    value="1"
                    min="1">



                <button class="btn btn-success mt-2">

                    Adicionar produto

                </button>


            </form>



            <p class="mt-3">

                Valor:

                <strong>
                    {% set valorTotal = 0 %}
                    {% for item in pedido.orderItems %}
                        {% set valorTotal = valorTotal + (item.precoUnitario * item.quantidade) %}
                    {% endfor %}
                    R$ {{ valorTotal|number_format(2, ',', '.') }}
                </strong>

            </p>


            <p>

                Status:

                <span class="badge bg-primary">
                    {{ pedido.status }}
                </span>

            </p>


            <form
                method="post"
                action="{{ path('app_pedido_status', { id: pedido.id }) }}">


                <select
                    name="status"
                    class="form-select">


                    <option value="AGUARDANDO_PAGAMENTO">
                        Aguardando pagamento
                    </option>


                    <option value="PAGO">
                        Pago
                    </option>


                    <option value="EM_TRANSPORTE">
                        Em transporte
                    </option>


                    <option value="ENTREGUE">
                        Entregue
                    </option>


                    <option value="CANCELADO">
                        Cancelado
                    </option>


                </select>



                <button class="btn btn-success mt-2">

                    Alterar status

                </button>


            </form>



            <hr>



            <h3>
                Documentos
            </h3>


            <form
                method="post"
                enctype="multipart/form-data"
                action="{{ path('app_pedido_documento', { id: pedido.id }) }}">


                <input
                    type="file"
                    name="documento"
                    class="form-control">


                <button class="btn btn-primary mt-2">

                    Enviar documento

                </button>


            </form>



            <br>



            <ul class="list-group">


                {% for documento in pedido.orderDocuments %}


                    <li class="list-group-item">


                        <a
                            href="/uploads/{{ documento.filePath }}"
                            target="_blank">


                            {{ documento.originalName }}


                        </a>


                    </li>


                {% else %}


                    <li class="list-group-item">

                        Nenhum documento enviado

                    </li>


                {% endfor %}


            </ul>



            <hr>



            <h3 class="mt-4">
                Histórico de status
            </h3>


            <table class="table table-hover shadow">


                <thead>


                    <tr>


                        <th>
                            Status anterior
                        </th>


                        <th>
                            Novo status
                        </th>


                        <th>
                            Data
                        </th>


                        <th>
                            Usuário
                        </th>


                    </tr>


                </thead>


                <tbody>


                {% for historico in pedido.orderStatusHistories %}


                    <tr>


                        <td>
                            {{ historico.oldStatus }}
                        </td>


                        <td>
                            {{ historico.newStatus }}
                        </td>


                        <td>
                            {{ historico.changedAt|date('d/m/Y H:i') }}
                        </td>


                        <td>


                            {% if historico.changedBy %}

                                {{ historico.changedBy.email }}

                            {% else %}

                                Sistema

                            {% endif %}


                        </td>


                    </tr>


                {% else %}


                    <tr>


                        <td
                            colspan="4"
                            class="text-center">

                            Nenhum histórico encontrado

                        </td>


                    </tr>


                {% endfor %}


                </tbody>


            </table>


        </div>


    </div>


</div>


{% endblock %}